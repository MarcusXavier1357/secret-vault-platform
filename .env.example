# Configurações do Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=vault_user
DB_PASSWORD=vault_password
DB_NAME=secret_vault
DB_SSLMODE=disable

# Configurações do Servidor Backend Go
PORT=8080

# Credenciais do Operador (Autenticação Mínima)
ADMIN_USER=admin
ADMIN_PASSWORD=senha_forte

# Assinatura de Sessão (HMAC-SHA256) - Mínimo 32 caracteres
SESSION_SECRET=super-secret-hmac-key-for-session-signing-minimum-32-bytes

# Chave Criptográfica AES-256-GCM (32 bytes hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
